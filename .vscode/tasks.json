    "tasks": [
        {
            "label": "YAPF",
            "type": "shell",
            "group": "none",
            "command": "${workspaceFolder}/.venv/Scripts/yapf.exe",
            "args": [
                "--style",
                "${workspaceFolder}/Fuzz/.style.yapf",
                "--recursive",
                "--in-place",
